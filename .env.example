# Copy this file to .env and adjust as needed:  cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# --- Database (must match docker-compose.yml) ---
# Prisma reads this single connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/express_mvc_db?schema=public"

# These mirror DATABASE_URL and are used by src/config/environment.ts
DB_HOST=localhost
DB_PORT=5432
DB_NAME=express_mvc_db
DB_USER=postgres
DB_PASSWORD=postgres

# --- Auth secrets (change these!) ---
ACCESS_TOKEN_SECRET=dev-access-secret-change-me
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=24h
